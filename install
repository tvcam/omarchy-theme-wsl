#!/bin/bash
# Omarchy WSL Installer
# Brings the Omarchy theme system (basecamp/omarchy) to WSL
# One command: curl -fsSL https://raw.githubusercontent.com/tvcam/omarchy-theme-wsl/main/install | bash
set -e

REPO="tvcam/omarchy-theme-wsl"
BRANCH="main"
INSTALL_DIR="/tmp/omarchy-wsl-install"

echo ""
echo "  ╔══════════════════════════════════════════╗"
echo "  ║        Omarchy WSL Theme Installer       ║"
echo "  ║  17 themes for Windows Terminal + VS Code║"
echo "  ╚══════════════════════════════════════════╝"
echo ""

# --- Detect Windows username ---
WIN_USER=$(/mnt/c/Windows/System32/cmd.exe /c "echo %USERNAME%" 2>/dev/null | tr -d '\r')
if [ -z "$WIN_USER" ]; then
  echo "Error: Could not detect Windows username. Are you running from WSL?"
  exit 1
fi
echo "  Windows user: $WIN_USER"

# --- Paths ---
WT_SETTINGS="/mnt/c/Users/$WIN_USER/AppData/Local/Packages/Microsoft.WindowsTerminal_8wekyb3d8bbwe/LocalState/settings.json"
WIN_BIN="/mnt/c/Users/$WIN_USER/bin"
WSL_BIN="$HOME/bin"
WIN_FONTS="/mnt/c/Users/$WIN_USER/AppData/Local/Microsoft/Windows/Fonts"

# --- Check prerequisites ---
if [ ! -f "$WT_SETTINGS" ]; then
  echo "Error: Windows Terminal settings not found at $WT_SETTINGS"
  echo "Please install Windows Terminal first."
  exit 1
fi

if ! command -v python3 &>/dev/null; then
  echo "Error: python3 is required. Install with: sudo apt install python3"
  exit 1
fi

if ! command -v git &>/dev/null; then
  echo "Error: git is required. Install with: sudo apt install git"
  exit 1
fi

# --- Clone repo ---
echo "  Downloading omarchy-wsl..."
rm -rf "$INSTALL_DIR"
git clone --depth 1 "https://github.com/$REPO.git" "$INSTALL_DIR" 2>/dev/null
echo "  Downloaded."

# --- Install color schemes ---
echo "  Installing 17 Omarchy color schemes..."
python3 -c "
import json

with open('$WT_SETTINGS', 'r') as f:
    settings = json.load(f)

with open('$INSTALL_DIR/schemes/omarchy-schemes.json', 'r') as f:
    new_schemes = json.load(f)

# Remove existing Omarchy schemes to avoid duplicates
existing = [s for s in settings.get('schemes', []) if not s.get('name', '').startswith('Omarchy ')]
existing.extend(new_schemes)
settings['schemes'] = existing

with open('$WT_SETTINGS', 'w') as f:
    json.dump(settings, f, indent=4)

print(f'  Added {len(new_schemes)} color schemes to Windows Terminal')
"

# --- Install fonts ---
echo "  Installing JetBrainsMono Nerd Font..."
mkdir -p "$WIN_FONTS"
cp "$INSTALL_DIR"/fonts/*.ttf "$WIN_FONTS/" 2>/dev/null || true

# Register fonts in Windows registry
font_count=0
for ttf in "$INSTALL_DIR"/fonts/*.ttf; do
  fname=$(basename "$ttf")
  # Extract font name from filename (e.g., JetBrainsMonoNerdFont-Bold.ttf → JetBrainsMono Nerd Font Bold)
  display=$(echo "$fname" | sed 's/\.ttf$//' | sed 's/-/ /g' | sed 's/NerdFont/Nerd Font/g' | sed 's/JetBrainsMono/JetBrainsMono /g')
  win_font_path="C:\\Users\\$WIN_USER\\AppData\\Local\\Microsoft\\Windows\\Fonts\\$fname"
  powershell.exe -NoProfile -Command "Set-ItemProperty -Path 'HKCU:\SOFTWARE\Microsoft\Windows NT\CurrentVersion\Fonts' -Name '$display (TrueType)' -Value '$win_font_path'" 2>/dev/null
  font_count=$((font_count + 1))
done
echo "  Installed $font_count font files"

# --- Set font on WSL profiles ---
echo "  Setting font on WSL terminal profiles..."
python3 -c "
import json

with open('$WT_SETTINGS', 'r') as f:
    settings = json.load(f)

font_config = {'face': 'JetBrainsMono Nerd Font', 'size': 9}

# Set on all WSL profiles
for profile in settings['profiles']['list']:
    source = profile.get('source', '')
    commandline = profile.get('commandline', '')
    if 'wsl' in source.lower() or 'wsl' in commandline.lower() or source == 'Microsoft.WSL':
        profile['font'] = font_config

with open('$WT_SETTINGS', 'w') as f:
    json.dump(settings, f, indent=4)

print('  Font set to JetBrainsMono Nerd Font (size 9) on WSL profiles')
"

# --- Install theme picker script ---
echo "  Installing theme picker..."
mkdir -p "$WSL_BIN"
cp "$INSTALL_DIR/bin/theme" "$WSL_BIN/theme"
chmod +x "$WSL_BIN/theme"

# --- Install GUI exe ---
mkdir -p "$WIN_BIN"
cp "$INSTALL_DIR/theme-picker.exe" "$WIN_BIN/theme-picker.exe"
echo "  Installed theme-picker.exe to C:\\Users\\$WIN_USER\\bin\\"

# --- Ensure ~/bin is in PATH ---
if ! echo "$PATH" | grep -q "$HOME/bin"; then
  for rc in "$HOME/.bashrc" "$HOME/.zshrc"; do
    if [ -f "$rc" ]; then
      if ! grep -q 'HOME/bin' "$rc"; then
        echo 'export PATH="$HOME/bin:$PATH"' >> "$rc"
        echo "  Added ~/bin to PATH in $(basename $rc)"
      fi
    fi
  done
  export PATH="$HOME/bin:$PATH"
fi

# --- Cleanup ---
rm -rf "$INSTALL_DIR"

echo ""
echo "  ✅ Omarchy WSL installed successfully!"
echo ""
echo "  Usage:"
echo "    theme              - interactive picker with live preview"
echo "    theme <name>       - apply theme directly"
echo "    theme --gui        - Windows GUI picker"
echo "    theme --list       - list available themes"
echo "    theme --uninstall  - remove omarchy-wsl"
echo ""
echo "  Available themes:"
echo "    catppuccin-latte, catppuccin, ethereal, everforest,"
echo "    flexoki-light, gruvbox, hackerman, kanagawa, matte-black,"
echo "    miasma, nord, osaka-jade, ristretto, rose-pine,"
echo "    tokyo-night, vantablack, white"
echo ""
echo "  You may need to restart your terminal for the font to take effect."
echo ""
